`timescale 1ns / 1ps

module fp_mul_tb;

    // 1. Khai báo các tín hiệu kết nối
    reg clk;
    reg [31:0] floatA;
    reg [31:0] floatB;
    wire [31:0] result;

    // 2. Khởi tạo module cần kiểm tra (DUT - Device Under Test)
    fp_mul dut (
        .clk(clk),
        .floatA(floatA),
        .floatB(floatB),
        .result(result)
    );

    // 3. Tạo xung nhịp (Clock) - Chu kỳ 10ns (100MHz)
    initial begin
        clk = 0;
        forever #5 clk = ~clk;
    end

    // 4. Kịch bản kiểm thử
    initial begin
        // Khởi tạo giá trị đầu
        floatA = 0;
        floatB = 0;

        // Chờ module ổn định
        #20;

        // --- Trường hợp 1: 2.0 * 3.0 = 6.0 ---
        // 2.0 = 0x40000000
        // 3.0 = 0x40400000
        // Kết quả kỳ vọng: 6.0 = 0x40C00000
        floatA = 32'h40000000; 
        floatB = 32'h40400000;
        #20; // Chờ qua các tầng Pipeline
        $display("Test 1: 2.0 * 3.0 | Result: %h (Expected: 40c00000)", result);

        // --- Trường hợp 2: 0.5 * 4.0 = 2.0 ---
        // 0.5 = 0x3F000000
        // 4.0 = 0x40800000
        // Kết quả kỳ vọng: 2.0 = 0x40000000
        floatA = 32'h3F000000;
        floatB = 32'h40800000;
        #20;
        $display("Test 2: 0.5 * 4.0 | Result: %h (Expected: 40000000)", result);

        // --- Trường hợp 3: Số âm * Số dương (-2.5 * 2.0 = -5.0) ---
        // -2.5 = 0xC0200000
        // 2.0  = 0x40000000
        // Kết quả kỳ vọng: -5.0 = 0xC0A00000
        floatA = 32'hC0200000;
        floatB = 32'h40000000;
        #20;
        $display("Test 3: -2.5 * 2.0 | Result: %h (Expected: c0a00000)", result);

        // --- Trường hợp 4: 1.5 * 1.5 = 2.25 ---
        // 1.5 = 0x3FC00000
        // Kết quả kỳ vọng: 2.25 = 0x40100000
        floatA = 32'h3FC00000;
        floatB = 32'h3FC00000;
        #20;
        $display("Test 4: 1.5 * 1.5 | Result: %h (Expected: 40100000)", result);

        // Kết thúc mô phỏng
        #100;
        $finish;
    end

    // 5. Theo dõi dạng sóng (Dùng cho ModelSim/Vivado)
    initial begin
        $monitor("At time %t: A=%h, B=%h, Result=%h", $time, floatA, floatB, result);
    end

endmodule
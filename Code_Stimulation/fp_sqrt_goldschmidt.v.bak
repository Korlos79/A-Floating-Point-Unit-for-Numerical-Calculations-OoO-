`timescale 1ns/1ps

module fp_sqrt_goldschmidt #(
    parameter PIPE_LAT = 13
)(
    input  wire        clk,
    input  wire        rst,
    input  wire        start,
    input  wire [3:0]  tag_in,
    input  wire [31:0] floatA,
    // Không cần floatB vì Căn bậc hai chỉ dùng 1 toán hạng
    output reg  [31:0] result,
    output reg         valid_out,
    output reg  [3:0]  tag_out
);

    localparam [31:0] FP_ZERO = 32'h00000000;
    localparam [31:0] FP_HALF = 32'h3F000000; // 0.5
    localparam [31:0] FP_NAN  = 32'h7FC00000; // Not a Number
    localparam        FMA_LAT = 2;            
    localparam        META_D  = 12; // Đường trễ tín hiệu điều khiển (12 chu kỳ)

    // ----------------------------------------------------------
    // VALID & TAG SHIFT REGISTERS
    // ----------------------------------------------------------
    reg [PIPE_LAT-2:0] valid_pipe;
    reg [3:0]          tag_pipe [0:PIPE_LAT-2];
    integer ti;

    always @(posedge clk) begin
        if (rst) begin
            valid_pipe <= 0;
            for (ti = 0; ti < PIPE_LAT-1; ti = ti + 1) tag_pipe[ti] <= 4'b0;
        end else begin
            valid_pipe <= {valid_pipe[PIPE_LAT-3:0], start};
            tag_pipe[0] <= tag_in;
            for (ti = 1; ti < PIPE_LAT-1; ti = ti + 1) tag_pipe[ti] <= tag_pipe[ti-1];
        end
    end

    // ----------------------------------------------------------
    // STAGE 0: BÓC TÁCH EXPONENT & CHUẨN BỊ X_in (Combinational)
    // ----------------------------------------------------------
    // Nếu exp[0]==1 (biased odd, unbiased even): X_in dùng exp=127 (Dải 1 -> 2)
    // Nếu exp[0]==0 (biased even, unbiased odd): X_in dùng exp=128 (Dải 2 -> 4)
    wire [31:0] X_in_wire = {1'b0, floatA[23] ? 8'd127 : 8'd128, floatA[22:0]};
    
    // Tính toán trước Số mũ (Exponent) đầu ra 
    // e_out = (e_in - 127) / 2 + 127
    wire signed [8:0] e_adj = {1'b0, floatA[30:23]} - 9'd127;
    wire signed [8:0] e_out = (e_adj >>> 1); // Dịch phải có dấu
    wire [7:0] final_exp_wire = e_out + 9'd127;

    // Bắt lỗi số âm và số 0
    wire is_zero_wire = (floatA[30:23] == 8'd0);
    wire is_neg_wire  = floatA[31] & ~is_zero_wire;

    // Pipeline cho X_in qua 2 nhịp để khớp với kết quả từ ROM
    reg [31:0] X_in_s0, X_in_s1;
    always @(posedge clk) begin
        X_in_s0 <= X_in_wire;
        X_in_s1 <= X_in_s0;
    end

    // ----------------------------------------------------------
    // STAGE 1 & 2: LUT ROM (1-cycle latency)
    // ----------------------------------------------------------
    wire [31:0] lut_y0_wire;
    sqrt_lut_rom lut_inst (
        .clk(clk),
        .lut_idx({floatA[23], floatA[22:16]}), // 8-bit index
        .lut_y0(lut_y0_wire)
    );

    reg [31:0] y0_r; // Valid ở Cycle 2
    always @(posedge clk) y0_r <= lut_y0_wire;

    // ----------------------------------------------------------
    // META PIPELINE: Trễ các cờ điều khiển đi 12 chu kỳ
    // ----------------------------------------------------------
    reg [7:0] final_exp_pipe [0:META_D-1];
    reg       is_zero_pipe   [0:META_D-1];
    reg       is_neg_pipe    [0:META_D-1];
    integer gi;

    always @(posedge clk) begin
        if (rst) begin
            for (gi = 0; gi < META_D; gi = gi + 1) begin
                final_exp_pipe[gi] <= 0; is_zero_pipe[gi] <= 0; is_neg_pipe[gi] <= 0;
            end
        end else begin
            final_exp_pipe[0] <= final_exp_wire;
            is_zero_pipe[0]   <= is_zero_wire;
            is_neg_pipe[0]    <= is_neg_wire;
            for (gi = 1; gi < META_D; gi = gi + 1) begin
                final_exp_pipe[gi] <= final_exp_pipe[gi-1];
                is_zero_pipe[gi]   <= is_zero_pipe[gi-1];
                is_neg_pipe[gi]    <= is_neg_pipe[gi-1];
            end
        end
    end

    // ==========================================================
    // THUẬT TOÁN GOLDSCHMIDT (7 BỘ FMA - Song song hóa)
    // ==========================================================
    
    // --- CYCLE 2 -> 4: Khởi tạo g0 và h0 ---
    wire [31:0] fma_g0, fma_h0;
    fp_fma u_g0 (.clk(clk), .floatA(X_in_s1), .floatB(y0_r),   .floatC(FP_ZERO), .result(fma_g0));
    fp_fma u_h0 (.clk(clk), .floatA(y0_r),    .floatB(FP_HALF),.floatC(FP_ZERO), .result(fma_h0));

    // Delay line cho g0 và h0 (đợi r0 tính xong)
    reg [31:0] g0_dly[0:1], h0_dly[0:1];
    always @(posedge clk) begin
        g0_dly[0] <= fma_g0; g0_dly[1] <= g0_dly[0];
        h0_dly[0] <= fma_h0; h0_dly[1] <= h0_dly[0];
    end

    // --- CYCLE 4 -> 6: Iteration 1 (Tính r0) ---
    // r0 = 0.5 - g0 * h0 = (-g0) * h0 + 0.5
    wire [31:0] neg_g0 = {~fma_g0[31], fma_g0[30:0]};
    wire [31:0] fma_r0;
    fp_fma u_r0 (.clk(clk), .floatA(neg_g0), .floatB(fma_h0), .floatC(FP_HALF), .result(fma_r0));

    // --- CYCLE 6 -> 8: Iteration 1 (Cập nhật g1 và h1) ---
    wire [31:0] fma_g1, fma_h1;
    fp_fma u_g1 (.clk(clk), .floatA(g0_dly[1]), .floatB(fma_r0), .floatC(g0_dly[1]), .result(fma_g1));
    fp_fma u_h1 (.clk(clk), .floatA(h0_dly[1]), .floatB(fma_r0), .floatC(h0_dly[1]), .result(fma_h1));

    // Delay line cho g1 và h1
    reg [31:0] g1_dly[0:1], h1_dly[0:1];
    always @(posedge clk) begin
        g1_dly[0] <= fma_g1; g1_dly[1] <= g1_dly[0];
        h1_dly[0] <= fma_h1; h1_dly[1] <= h1_dly[0];
    end

    // --- CYCLE 8 -> 10: Iteration 2 (Tính r1) ---
    wire [31:0] neg_g1 = {~fma_g1[31], fma_g1[30:0]};
    wire [31:0] fma_r1;
    fp_fma u_r1 (.clk(clk), .floatA(neg_g1), .floatB(fma_h1), .floatC(FP_HALF), .result(fma_r1));

    // --- CYCLE 10 -> 12: Iteration 2 (Kết quả cuối g2 = Sqrt(X_in)) ---
    wire [31:0] fma_g2;
    fp_fma u_g2 (.clk(clk), .floatA(g1_dly[1]), .floatB(fma_r1), .floatC(g1_dly[1]), .result(fma_g2));

    // ==========================================================
    // OUTPUT STAGE (CYCLE 13): GHI VÀO RESULT
    // ==========================================================
    wire       is_neg_final = is_neg_pipe[META_D-1];
    wire       is_zero_final= is_zero_pipe[META_D-1];
    wire [7:0] exp_final    = final_exp_pipe[META_D-1];
    
    // Cộng trừ bù hao nếu bộ FMA cuối cùng thực hiện Normalize mantissa
    wire [7:0] exp_sqrt_raw = fma_g2[30:23];
    wire [7:0] exp_result   = exp_final + exp_sqrt_raw - 8'd127;

    always @(posedge clk) begin
        if (rst) begin
            result    <= 32'b0; 
            valid_out <= 1'b0;
            tag_out   <= 4'b0;
        end else begin
            valid_out <= valid_pipe[PIPE_LAT-2];
            tag_out   <= tag_pipe[PIPE_LAT-2]; 

            if (is_zero_final)
                result <= FP_ZERO;
            else if (is_neg_final)
                result <= FP_NAN; // Lỗi Căn bậc hai số âm ra NaN
            else
                result <= {1'b0, exp_result, fma_g2[22:0]};
        end
    end

endmodule
module fp_mul (
    input clk,
    input [31:0] floatA,
    input [31:0] floatB,
    output reg [31:0] result
);

    // =============================================================
    // STAGE 1: INPUT LATCH & EXTRACTION
    // =============================================================
    reg [23:0] mantA_s1, mantB_s1;
    reg [7:0]  expA_s1, expB_s1;
    reg        signA_s1, signB_s1;

    always @(posedge clk) begin
        signA_s1 <= floatA[31];
        signB_s1 <= floatB[31];
        expA_s1  <= floatA[30:23];
        expB_s1  <= floatB[30:23];
        // Thêm bit 1 ẩn (Hidden bit)
        mantA_s1 <= {1'b1, floatA[22:0]};
        mantB_s1 <= {1'b1, floatB[22:0]};
    end

    // =============================================================
    // STAGE 2: 24x24 MULTIPLICATION (Sử dụng Embedded Multipliers)
    // =============================================================
    // Việc chia nhỏ phép nhân giúp Fmax tăng vọt trên Cyclone II
    reg [47:0] prod_s2;
    reg [8:0]  exp_sum_s2;
    reg        sign_s2;

    always @(posedge clk) begin
        prod_s2    <= mantA_s1 * mantB_s1; 
        exp_sum_s2 <= expA_s1 + expB_s1;
        sign_s2    <= signA_s1 ^ signB_s1;
    end

    // =============================================================
    // STAGE 3: PIPELINE BARRIER (Giảm trễ cho bộ cộng số mũ)
    // =============================================================
    reg [47:0] prod_s3;
    reg [8:0]  exp_sub_bias_s3;
    reg        sign_s3;

    always @(posedge clk) begin
        prod_s3 <= prod_s2;
        sign_s3 <= sign_s2;
        // Trừ Bias 127 ngay tại đây để giảm tải cho Stage 4
        exp_sub_bias_s3 <= exp_sum_s2 - 9'd127;
    end

    // =============================================================
    // STAGE 4: NORMALIZATION (Kỹ thuật dịch bit tối ưu)
    // =============================================================
    reg [22:0] mant_out_s4;
    reg [7:0]  exp_out_s4;
    reg        sign_out_s4;

    always @(posedge clk) begin
        sign_out_s4 <= sign_s3;
        // Kiểm tra bit tràn (Overflow bit tại vị trí 47)
        if (prod_s3[47]) begin
            mant_out_s4 <= prod_s3[46:24];
            exp_out_s4  <= exp_sub_bias_s3 + 1'b1;
        end else begin
            mant_out_s4 <= prod_s3[45:23];
            exp_out_s4  <= exp_sub_bias_s3[7:0];
        end
    end

    // =============================================================
    // STAGE 5: EXCEPTION HANDLING & FINAL OUTPUT
    // =============================================================
    // Thêm kiểm tra Overflow/Underflow để đồ án xịn hơn bài báo
    always @(posedge clk) begin
        if (exp_out_s4 >= 8'd255) // Tràn số (Overflow)
            result <= {sign_out_s4, 8'hFF, 23'h0}; 
        else if (exp_out_s4 <= 8'd0) // Thiếu số (Underflow)
            result <= {sign_out_s4, 31'h0};
        else
            result <= {sign_out_s4, exp_out_s4, mant_out_s4};
    end

endmodule